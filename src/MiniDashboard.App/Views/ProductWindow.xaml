<Window x:Class="MiniDashboard.App.Views.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniDashboard.App.Views"
        mc:Ignorable="d"
        Title="ProductWindow" Height="450" Width="800"
        xmlns:vm="clr-namespace:MiniDashboard.App.ViewModels"
        xmlns:conv="clr-namespace:MiniDashboard.App.Infrastructure.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:BoolToVisibilityConverter x:Key="InverseVisibilityConverter" Invert="True" />

        <conv:StatusTypeToVisibilityConverter x:Key="StatusVisibilityConverter"/>
        <conv:StatusTypeToBackgroundConverter x:Key="StatusBackgroundConverter"/>
        <conv:StatusTypeToIconConverter x:Key="StatusIconConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <!--Title-->
        <Label
            Grid.Row="0"
            Grid.Column="1"
            Content="PRODUCT DASHBOARD"
            FontWeight="Bold"
            FontSize="20"
            Padding="0"
            VerticalContentAlignment="Center"/>

        <!--Filter-->
        <Grid 
            Grid.Row="1"
            Grid.Column="1"
            MinHeight="25"
            Background="WhiteSmoke">
            <Grid
                Visibility="{Binding IsFilterVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="5"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="175"/>
                    </Grid.ColumnDefinitions>

                    <Label
                        Content="Name: "
                        Grid.Row="0"
                        Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalContentAlignment="Center"/>

                    <ComboBox
                        Grid.Row="0"
                        Grid.Column="2"
                        ItemsSource="{Binding Path=Filter.Name.FilterTypes, UpdateSourceTrigger=PropertyChanged}"
                        SelectedValue="{Binding Path=Filter.Name.SelectedFilterType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        DisplayMemberPath="Key"
                        SelectedValuePath="Value">
                    </ComboBox>

                    <TextBox
                        Grid.Row="0"
                        Grid.Column="4"
                        VerticalContentAlignment="Center"
                        Padding="0"
                        Text="{Binding Path=Filter.Name.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid
                    Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <Label
                        Content="Price Min:"
                        Width="70"
                        Grid.Column="0"
                        HorizontalAlignment="Left"/>

                    <TextBox
                        Grid.Column="2"
                        VerticalContentAlignment="Center"
                        Padding="0"
                        Text="{Binding Path=Filter.MinPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label
                        Content="Price Max:"
                        Width="70"
                        Grid.Column="4"
                        HorizontalAlignment="Left"/>

                    <TextBox
                        Grid.Column="6"
                        VerticalContentAlignment="Center"
                        Padding="0"
                        Text="{Binding Path=Filter.MaxPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
                
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Grid.Row="2"
                    Content="Filter"
                    Padding="10,0"
                    Command="{Binding Path=FilterProductsCommand}"/>
            </Grid>

            <Label
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Height="25"
                Padding="0"
                VerticalContentAlignment="Center"
                Content="{Binding Path=Filter.Summary, Mode=OneWay}"
                Visibility="{Binding Path=IsFilterVisible, Mode=OneWay, Converter={StaticResource InverseVisibilityConverter}}"/>

            <Button 
                Command="{Binding FilterVisibilityCommand}"
                Background="Transparent"
                BorderThickness="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                ToolTip="Filter">
                <Grid>
                    <Path 
                        Width="23"
                        Height="20"
                        Fill="Gray"
                        Data="M 5 16 L 19 16 L 12 6 Z"
                        Visibility="{Binding Path=IsFilterVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <Path 
                        Width="23"
                        Height="20"
                        Fill="Gray"
                        Data="M 5 6 L 19 6 L 12 16 Z"
                        Visibility="{Binding Path=IsFilterVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource InverseVisibilityConverter}}"/>
                </Grid>
            </Button>

        </Grid>

       

        <!--Grid View-->
        <ItemsControl
            Grid.Row="3"
            Grid.Column="1"
            ItemsSource="{Binding Products}">
            <ItemsControl.Resources>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Margin" Value="0,2"/>
                </Style>
            </ItemsControl.Resources>

            <ItemsControl.Template>
                <ControlTemplate 
                    TargetType="ItemsControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="25"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid 
                            Grid.Row="0"
                            Background="WhiteSmoke">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="350"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock 
                                Text="Name"
                                FontWeight="Bold"
                                Grid.Column="0"
                                Padding="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                            <TextBlock 
                                Text="Description"
                                FontWeight="Bold"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                            <TextBlock 
                                Text="Price"
                                FontWeight="Bold"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                            
                            <TextBlock Text=""
                               Grid.Column="3"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Grid>
                </ControlTemplate>
            </ItemsControl.Template>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"
                           Grid.Column="0"/>

                        <TextBlock Text="{Binding Description}"
                           VerticalAlignment="Center"
                           Grid.Column="1"/>

                        <TextBlock Text="{Binding Price}"
                           VerticalAlignment="Center"
                           Grid.Column="2"/>

                        <Button Grid.Column="3"
                            Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="2"
                            ToolTip="Delete product">
                            <Path 
                                Width="18"
                                Height="18"
                                Fill="Gray"
                                Stretch="Uniform"
                                Data="M6 7 H18 V19 C18 20.1 17.1 21 16 21 H8 C6.9 21 6 20.1 6 19 V7 Z
          M9 3 H15 V5 H21 V7 H3 V5 H9 V3 Z"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>

        <Button
            Content="Add Product"
            Grid.Row="4"
            Grid.Column="1"
            HorizontalAlignment="Right"
            Padding="15,0"
            Command="{Binding Path=AddProductCommand}"
            />

        <!--Busy Overlay-->
        <Grid 
            Grid.Row="1"
            Grid.Column="1"
            Grid.RowSpan="4"
            Visibility="Hidden">
            <!--Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"-->
            <Grid
                Background="#77000000">                
            </Grid>
            
            <StackPanel 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center">
                <TextBlock 
                    Text="Loading..."
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"/>

                <ProgressBar 
                    Width="200"
                    Height="12"
                    IsIndeterminate="True"
                    Margin="0,10,0,0"/>
            </StackPanel>

        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Grid.RowSpan="4"
            Background="#77000000"
            Visibility="{Binding Path=AddingProduct, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid
                Background="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Height="Auto"
                Width="Auto">
                <Grid.RowDefinitions>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="10"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="10"/>
                </Grid.ColumnDefinitions>

                <Label
                    Grid.Row="1" Grid.Column="1"
                    Padding="0"
                    Content="Add New Product"
                    Grid.ColumnSpan="4"
                    FontSize="15"/>

                <Label
                    Grid.Row="3" Grid.Column="1"
                    Padding="0"
                    Content="Name : "
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Right"/>

                <TextBox
                    Grid.Row="3"
                    Grid.Column="3"
                    VerticalContentAlignment="Center"
                    Padding="0"
                    Text="{Binding Path=NewProduct.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Label
                    Grid.Row="5" Grid.Column="1"
                    Padding="0"
                    Content="Description : "
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Right"/>

                <TextBox
                    Grid.Row="5"
                    Grid.Column="3"
                    VerticalContentAlignment="Center"
                    Padding="0"
                    Text="{Binding Path=NewProduct.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                
                <Label
                    Grid.Row="7" Grid.Column="1"
                    Padding="0"
                    Content="Price : "
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Right"/>

                <TextBox
                    Grid.Row="7"
                    Grid.Column="3"
                    VerticalContentAlignment="Center"
                    Padding="0"
                    Text="{Binding Path=NewProduct.Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button
                    Grid.Column="3"
                    Grid.Row="9"
                    Content="Cancel"
                    Padding="15,2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Command="{Binding Path=CancelNewProductCommand}"/>

                <Button
                    Grid.Column="3"
                    Grid.Row="9"
                    Content="Save"
                    Padding="25,2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Command="{Binding Path=SaveNewProductCommand}"/>
            </Grid>

        </Grid>


        <Grid 
            Grid.Row="6"
            Grid.Column="1"
            Background="{Binding StatusMessage.Type, Converter={StaticResource StatusBackgroundConverter}}"
            Visibility="{Binding StatusMessage.Type, Converter={StaticResource StatusVisibilityConverter}}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <Path
                Grid.Column="0"
                Width="18"
                Height="18"
                Fill="Black"
                Stretch="Uniform"
                Data="{Binding StatusMessage.Type, Converter={StaticResource StatusIconConverter}}"/>

            <!-- Message -->
            <TextBlock
                Grid.Column="1"
                Text="{Binding StatusMessage.Message}"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Foreground="Black"/>
        </Grid>
    </Grid>
</Window>
